# Copy to .env and fill in.

# =============================================================================
# Translator backend (the one knob most worth tuning)
# =============================================================================

# Which backend to use:
#   claude_agent (default) — Claude Agent SDK in-process. Opus 4.7 with
#                            extended thinking. No subprocess cold-start;
#                            runs against the local `claude` subscription
#                            (the binary must be installed and logged in).
#                            Single-pass — every call burns the subscription
#                            window. Each chapter is a fresh stateless call.
#   claude_cli             — same subscription, but spawns a `claude`
#                            subprocess per chapter. No extended-thinking
#                            plumbing, so quality is below claude_agent.
#                            Kept as a fallback when the SDK has issues.
#   gemini                 — Gemini API (requires GEMINI_API_KEY). Defaults
#                            to gemini-3-pro-preview. Useful for parity
#                            testing or when claude_agent quota is exhausted.
#   deepseek               — DeepSeek API (requires DEEPSEEK_API_KEY).
#                            Cheap, fast; single-pass translator.
TRANSLATOR_BACKEND=claude_agent

# Thinking-effort level for the claude_agent translator: low / medium /
# high / xhigh / max. Default "high" enables Opus 4.7 extended thinking
# (the lever for first-pass literary quality). "xhigh" goes deeper at
# higher per-chapter quota cost; "low" effectively disables thinking.
# Blank → SDK default.
CLAUDE_AGENT_TRANSLATOR_EFFORT=high

# =============================================================================
# Per-novel prompt context (the new layers added 2026-05-22)
# =============================================================================

# Whether to inject the tail of the previous chapter (English) into the
# translator prompt as a tone reference. Default on.
# PREVIOUS_CONTEXT_ENABLED=1

# Number of tail paragraphs from the previous chapter to include.
# PREVIOUS_CONTEXT_PARAGRAPHS=4

# Maximum backward chapter gap when searching for the nearest completed
# previous chapter. Default 10 — guards against a chapter-100 tail bleeding
# into a chapter-200 translation across a time-skip the source did not
# warrant.
# PREVIOUS_CONTEXT_MAX_GAP=10

# =============================================================================
# Per-backend keys + models
# =============================================================================

# Required when TRANSLATOR_BACKEND=gemini.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Gemini translator model override. Default gemini-3-pro-preview.
# GEMINI_TRANSLATOR_MODEL=gemini-3-pro-preview

# Optional: per-request timeout (seconds) for Gemini API calls. Default 240.
# GEMINI_REQUEST_TIMEOUT=240

# Required when TRANSLATOR_BACKEND=deepseek. Get one from platform.deepseek.com.
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Optional: DeepSeek translator model override. Default deepseek-v4-pro.
# DEEPSEEK_TRANSLATOR_MODEL=deepseek-v4-pro

# Optional: sampling temperature for the DeepSeek translation call. Default 0.7.
# DEEPSEEK_TRANSLATOR_TEMPERATURE=0.7

# Optional: max output tokens per DeepSeek call. Default 8192.
# DEEPSEEK_MAX_OUTPUT_TOKENS=8192

# Optional: per-request timeout (seconds). Default 240.
# DEEPSEEK_REQUEST_TIMEOUT=240

# Optional: path to the Claude CLI binary. Default "claude" on PATH.
# CLAUDE_CLI_PATH=claude

# Optional: model override for the claude_cli translator. Default
# claude-opus-4-5. The CLI has no thinking-config surface plumbed, so use
# claude_agent if you want extended thinking.
# CLAUDE_CLI_TRANSLATOR_MODEL=claude-opus-4-5

# Optional: model override for the claude_agent (SDK) translator. Default
# claude-opus-4-7 — the model `effort=high` extended thinking is plumbed for.
# CLAUDE_AGENT_TRANSLATOR_MODEL=claude-opus-4-7

# Optional: per-call timeout (seconds) for the claude_agent SDK. Default 600.
# A long-chapter Opus translation with extended thinking finishes inside 8min;
# a longer wait means a hung call.
# CLAUDE_AGENT_CALL_TIMEOUT=600

# =============================================================================
# Storage
# =============================================================================

# Optional: SQLite path. Default data/novels.db.
# DB_PATH=data/novels.db

# =============================================================================
# Miscellaneous
# =============================================================================

# Optional: when set to "1", the URL scraper sends a transparent
# `LN-Translator/0.1` User-Agent (with no Sec-Ch-Ua client hints) so site
# operators can see who's hitting them. Default behaviour shapes the
# request like Chrome-on-Windows so Cloudflare and friends don't
# reflexively 403 the import. Toggle this only if you're hitting sites
# that prefer polite UAs and you don't mind being recognized as a bot.
# LN_TRANSLATOR_POLITE_UA=0
