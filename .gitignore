__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
.env
# All of data/ is user-mutable runtime state (novels.db, llm_cache, runtime
# files written by Claude Agent's system-prompt cache). Bundled prompts live
# under backend/prompts/ (tracked normally) so the EXE build can ship them
# inside sys._MEIPASS while data/ stays purely per-user.
data/*
*.db
.pytest_cache/
tmp/
# Per-novel canonical-edits manuscripts live at the project root as .docx;
# they're the user's personal edited work and don't belong in the public repo.
*.docx
.claude/settings.local.json
.claude/*.lock
.DS_Store
# PyInstaller build artifacts. Rebuilt by scripts/smoke-exe.ps1 from
# LN-Translator.spec; keeping them out of the repo prevents 100+ MB
# binary diffs and stale-bundle confusion.
build/
dist/
# Side-channel distpath used when dist/ is locked by the running EXE.
dist-release/
# Working directories for parallel agents — never represent committed state.
.codex-temp/
# Per-run migration-check scratch dirs (random suffix per run).
ln-migration-check-*/
# Design tooling scratch (Figma exports, mockups, etc.) — not part of source.
.design-bundle/
# Local PyInstaller release zips. Built artifacts belong on the GitHub
# release page, not in git.
LN-Translator-*.zip
# Scratch dir for release-asset shuffling.
.release-tmp/
# PyInstaller log dump (created by the smoke harness; safe to discard).
build-log.txt
# Project-local MCP server config: machine-specific absolute paths, not portable.
# The portable artifact is the committed server script under tools/.
.mcp.json
# Serena MCP project symbol cache.
.serena/
# Local Claude Code skills: may carry machine-specific paths / internal notes.
.claude/skills/
# Desloppify local state (scan cache, living plan, review packets): not committed.
.desloppify/
# Desloppify generated health badge: regenerated every scan, binary churn.
scorecard.png
